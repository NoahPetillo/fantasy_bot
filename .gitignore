# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.uv/

# Secrets & local config
.env
config/league.yaml
*.secret

# Data / model artifacts (regenerable, can be large). Anchored to the repo root
# with a leading slash so it ONLY ignores the top-level runtime data/ dir and does
# NOT match the fantasy/data/ source package — the unanchored form dropped
# fantasy/data from the built wheel and crashed the container on startup.
/data/
!/data/.gitkeep
*.parquet
*.sqlite
*.sqlite3
*.db
models/*.pkl
models/*.json
models/*.ubj

# Claude Code local state (machine-specific permission cache)
.claude/settings.local.json

# Vendored Clerk agent-skill docs (installed by the Clerk CLI; not app code).
# We track skills-lock.json for reproducibility but not the ~140 doc/template files.
.agents/
.claude/skills/

# OS / editor
.DS_Store
.ipynb_checkpoints/
.idea/
.vscode/

# Playwright
/test-results/
/playwright-report/

.env.local
