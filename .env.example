# Copy to .env and fill in. .env is gitignored — never commit real secrets.
# See DEPLOY.md and MULTITENANT_BUILD.md for details.

# ── Multi-tenant SaaS infrastructure ─────────────────────────────────────────
# Neon Postgres. Leave unset for a local SQLite fallback (single-box dev only).
DATABASE_URL=
# Fernet key encrypting users' ESPN cookies at rest (NEVER stored in the DB).
# Generate one with:  python -m fantasy.security.crypto
CREDENTIAL_ENC_KEY=
# Clerk (managed auth — do not hand-roll auth).
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional: pin the Clerk issuer/JWKS URL (otherwise derived from the token).
CLERK_ISSUER=
# CLERK_JWKS_URL=

# ── Stripe (subscriptions). Unset → billing disabled (everyone stays on Free).
#    STRIPE_PRICE_ID is the recurring price of the Pro plan (price_… from Stripe).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# ── LLM (chatbot). Set at least one; without any key a keyless parser is used. ──
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# ── Legacy single-tenant ESPN vars (used only for the optional dev import of
#    your own league; per-user cookies are stored encrypted in the DB). ──
ESPN_S2=
ESPN_SWID=
ESPN_LEAGUE_ID=
ESPN_SEASON=2025
ESPN_TEAM_ID=

# ── Chatbot abuse floor (per-IP; per-user plan quota is enforced separately) ──
CHAT_RATE_LIMIT=250

# ── Content engine (optional) ──
DISCORD_WEBHOOK_URL=
